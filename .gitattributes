# Normalize line endings: store text as LF in the repo, prevent CRLF churn on Windows.
* text=auto eol=lf

# Binary assets — never touch line endings.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.pdf binary
*.zip binary
*.gz binary
*.exe binary
*.dll binary
*.dylib binary
*.so binary
*.lib binary
*.node binary

# Windows scripts keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
